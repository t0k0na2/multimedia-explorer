<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="main.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="main">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Folder Tree -->
        <TreeView x:Name="FolderTreeView" 
                  Grid.Column="0" 
                  SelectionMode="Single"
                  Expanding="FolderTreeView_Expanding" 
                  ItemInvoked="FolderTreeView_ItemInvoked"
                  Padding="8,16,8,8">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="TreeViewNode">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="{x:Bind ((local:ExplorerItem)Content).Icon}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ((local:ExplorerItem)Content).Name}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Right Pane: existing Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Control Panel -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="16" Spacing="16">
                <!-- Directory select button removed -->
                <TextBlock x:Name="SelectedDirectoryTextBlock" VerticalAlignment="Center" Text="ディレクトリが選択されていません。" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                <Slider x:Name="ZoomSlider" Minimum="60" Maximum="600" Value="120" Width="200" VerticalAlignment="Center" Header="ズーム" />
            </StackPanel>

            <!-- GridView for Files and Folders -->
            <GridView Grid.Row="1" x:Name="FileSystemGridView" Padding="16" SelectionMode="Single"
                      PointerWheelChanged="FileSystemGridView_PointerWheelChanged">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:FileSystemItem">
                        <StackPanel Width="{Binding ElementName=ZoomSlider, Path=Value}" Padding="8" Spacing="8" Background="Transparent" CornerRadius="4">
                            <Viewbox Stretch="Uniform" StretchDirection="Both">
                                <Grid Width="100" Height="100">
                                    <FontIcon Glyph="{x:Bind Icon}" FontSize="64" Visibility="{x:Bind FontIconVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <local:AnimatedImageControl ImagePath="{x:Bind Path}" TargetSize="{Binding ElementName=ZoomSlider, Path=Value}" Visibility="{x:Bind ImageIconVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <MediaPlayerElement Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill" />
                                    <Button Visibility="{x:Bind AudioButtonVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="0" Click="AudioPlayButton_Click" Tag="{x:Bind Path}">
                                        <FontIcon Glyph="&#xE768;" FontSize="48" Margin="0" />
                                    </Button>
                                    <Button Visibility="{x:Bind VideoButtonVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="0" Click="VideoPlayButton_Click" Tag="{x:Bind Path}">
                                        <FontIcon Glyph="&#xE768;" FontSize="48" Margin="0" />
                                    </Button>
                                    <Button Visibility="{x:Bind ModelButtonVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="0" Click="ModelPlayButton_Click" Tag="{x:Bind Path}">
                                        <FontIcon Glyph="&#xE943;" FontSize="48" Margin="0" />
                                    </Button>
                                </Grid>
                            </Viewbox>
                            <TextBlock Text="{x:Bind Name}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>

        <!-- 3D Viewer Overlay -->
        <Grid x:Name="ModelViewerOverlay" Grid.Column="1" Visibility="Collapsed" Background="#CC000000">
            <controls:WebView2 x:Name="ModelWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="20" Background="Transparent" Foreground="Black" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Padding="10" Click="CloseModelViewer_Click" />
        </Grid>
    </Grid>
</Window>
